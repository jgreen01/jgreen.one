---
/**
 * Props:
 * - entry: a single content collection entry
 */
import { type CollectionEntry } from "astro:content";
const { entry } = Astro.props;
const { data, collection } = entry;
let heroImagePath = data.heroImage;
if (heroImagePath && !heroImagePath.startsWith('/')) {
  heroImagePath = `/entries/${heroImagePath}`;
}
---

<li class="mb-6">
  <div class="flex gap-4">
    <!-- Hero Image -->
    <div class="flex-shrink-0 w-24 h-24">
      {data.heroImage ? (
        <img 
          src={heroImagePath} 
          alt={data.title}
          class="w-full h-full object-cover rounded-lg"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full bg-muted dark:bg-muted-foreground/20 rounded-lg flex items-center justify-center">
          <span class="text-muted-foreground text-xs">No Image</span>
        </div>
      )}
    </div>
    
    <!-- Content -->
    <div class="flex-1 min-w-0">
      <a href={`/${collection}/${entry.slug}`} class="text-xl font-semibold text-accent dark:text-accentDark hover:underline">
        {data.title}
      </a>
      <p class="text-sm text-muted-foreground dark:text-muted-foreground mt-1">
        <span class="capitalize">{collection}</span> &bull; {data.pubDate.toLocaleDateString('en-us', { year:"numeric", month:"short", day:"numeric"})}
      </p>
      {data.description && <p class="text-foreground/80 dark:text-foregroundDark/80 mt-1">{data.description}</p>}
      <div class="flex flex-wrap gap-2 mt-2">
        {data.tags.map((tag) => <span class="text-xs font-semibold text-accent dark:text-accentDark bg-accent/10 dark:bg-accentDark/10 px-2 py-1 rounded-full">#{tag}</span>)}
      </div>
    </div>
  </div>
</li>
